# ===== P0 security hardening (xem SECURITY.md và P0_MANUAL_ACTIONS.md) =====

# Apps Script service authentication
# BẮT BUỘC cho các script Python gọi action "service" (08_process_field_documents_batch.py,
# 11_sync_webapp_to_planner.py, 12_sync_planner_to_webapp.py — action import_vbqppl_nhap /
# update_vbqppl_record). KHÔNG còn fallback về APPS_SCRIPT_TOKEN — thiếu biến này, các script
# trên sẽ dừng ngay (08) hoặc bị Apps Script từ chối SERVICE_TOKEN_INVALID (11, 12).
# APPS_SCRIPT_TOKEN (ở trên) là token công khai nhúng trong Dashboard/index.html — chỉ dùng cho
# action đọc công khai (get_pending_records, get_all_records...) và làm cổng nhận diện ứng dụng
# ở tầng ngoài cùng; token đó KHÔNG còn mở khoá được bất kỳ action service/ghi dữ liệu nào.
APPS_SCRIPT_SERVICE_TOKEN=

# Planner Sync Server
PLANNER_SYNC_SHARED_SECRET=
PLANNER_SYNC_ALLOWED_ORIGINS=https://tracuuphaply.vercel.app,http://localhost:5500,http://127.0.0.1:5500
PLANNER_SYNC_REQUEST_TTL_SECONDS=300
PLANNER_SYNC_MAX_BODY_BYTES=1048576

# Admin authentication
ADMIN_SESSION_TTL_SECONDS=900
ADMIN_PASSWORD_SALT=
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_ITERATIONS=210000
ADMIN_SESSION_SECRET=

# Logging
WEBAPP_LOG_VERBOSE_DEBUG=false
